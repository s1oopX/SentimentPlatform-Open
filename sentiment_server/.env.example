# ⚠️ 所有密码/密钥字段必须在复制后立即修改，切勿使用示例值
# SECRET_KEY is required — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# JWT_SIGNING_KEY is required — JWT tokens are signed with this key instead of SECRET_KEY.
JWT_SIGNING_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Database
DB_ENGINE=django.db.backends.mysql
DB_NAME=sentiment_analysis
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# Redis / Celery
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Model runtime
MODEL_WORKSPACE_DIR=ml_assets
MODEL_PATH=ml_assets/models/bert
MODEL_MAX_LENGTH=256
MODEL_KEYWORD_TOP_K=5
MODEL_KEYWORD_MODE=hybrid
USE_GPU=False

# File system
REPORT_ROOT=generated_reports
EXPORT_ROOT=exports
MAX_UPLOAD_SIZE=10485760

# System config (replaces database-stored SystemConfig)
MAX_BATCH_RECORDS=1000
AUTO_RETRAIN_ENABLED=True
AUTO_RETRAIN_MODE=auto
AUTO_RETRAIN_THRESHOLD=5000
AUTO_RETRAIN_MAX_BATCHES_PER_CHECK=3
OPERATION_LOG_RETENTION_DAYS=180
REPORT_PDF_TITLE=情感分析报告
REPORT_PDF_SUBTITLE=Sentiment Analysis Report

# ── OpenAPI / Swagger UI ──────────────────────────────
# SWAGGER_ENABLED=False
