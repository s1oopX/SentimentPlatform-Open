{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": false,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client", "node"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.js", "src/**/*.vue", "src/**/*.d.ts", "vite.config.js", "eslint.config.js"],
  "exclude": ["dist", "node_modules", "vendor"]
}
